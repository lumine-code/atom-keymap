{
  "name": "@lumine-code/atom-keymap",
  "author": "lumine-code",
  "version": "10.0.0",
  "description": "Provides DOM-aware keymap management for Lumine and Electron applications.",
  "main": "./src/keymap-manager",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); for (const path of ['lib', 'api.json']) fs.rmSync(path, {recursive:true, force:true})\"",
    "test": "electron-mocha --renderer --no-sandbox --preload spec/helpers/setup.js spec/*-spec.*",
    "test-drive": "cross-env SUPPRESS_EXIT=true electron-mocha --no-colors --renderer --interactive --preload spec/helpers/setup.js spec/*-spec.*",
    "rebuild": "electron-rebuild -f -w keyboard-layout"
  },
  "repository": "https://github.com/lumine-code/atom-keymap",
  "bugs": "https://github.com/lumine-code/atom-keymap/issues",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@electron/rebuild": "^4.2.0",
    "clear-cut": "^2",
    "event-kit": "^2.5.3",
    "fs-plus": "https://github.com/lumine-code/fs-plus.git#6be512460cd7a6d617277f9608b3fcba264cb3be",
    "grim": "^2.0.3",
    "@lumine-code/keyboard-layout": "https://github.com/lumine-code/keyboard-layout.git#925a7d94243fa2ef3e971513feea36b85374a3de",
    "@lumine-code/pathwatcher": "https://github.com/lumine-code/node-pathwatcher.git#de08d8a2c3bd1c18aabc0669920c7ae2e895241a",
    "season": "https://github.com/lumine-code/season.git#721e25f3a41fd9b73419bba7af5057c1a006fd5d"
  },
  "devDependencies": {
    "@sinonjs/fake-timers": "^15.0.0",
    "chai": "^4.5.0",
    "coffeescript": "^2.7.0",
    "cross-env": "^10.1.0",
    "debounce": "^2.2.0",
    "electron": "43.1.0",
    "electron-mocha": "^13.1.0",
    "sinon": "^22.0.0",
    "space-pencil": "0.3.0"
  },
  "overrides": {
    "brace-expansion@2.0.1": "2.0.3",
    "diff": "^8.0.3",
    "glob": "^10.5.0",
    "js-yaml": "^4.3.0",
    "minimatch": "^9.0.7",
    "serialize-javascript": "^7.0.5"
  }
}

{
  "name": "@lumine-code/atom-keymap",
  "author": "lumine-code",
  "version": "10.0.0",
  "description": "Provides DOM-aware keymap management for Lumine and Electron applications.",
  "main": "./src/keymap-manager",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); for (const path of ['lib', 'api.json']) fs.rmSync(path, {recursive:true, force:true})\"",
    "test": "electron --no-sandbox spec/support/runner",
    "test-drive": "cross-env SUPPRESS_EXIT=true electron --no-sandbox spec/support/runner",
    "rebuild": "electron-rebuild -f -w keyboard-layout"
  },
  "repository": "https://github.com/lumine-code/atom-keymap",
  "bugs": "https://github.com/lumine-code/atom-keymap/issues",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@electron/rebuild": "^4.2.0",
    "clear-cut": "^2",
    "event-kit": "^2.5.3",
    "@lumine-code/fs-plus": "https://github.com/lumine-code/fs-plus.git#742e3e166f56261189ff245a63967b8f1970fadd",
    "grim": "^2.0.3",
    "@lumine-code/keyboard-layout": "https://github.com/lumine-code/keyboard-layout.git#73b62b1301fd7a18a0c0567ff8c1a6ebe1fa5d94",
    "@lumine-code/pathwatcher": "https://github.com/lumine-code/node-pathwatcher.git#ffe5b7b29242c9031e11a0df85f7c0d79f6cc990",
    "@lumine-code/season": "https://github.com/lumine-code/season.git#8cd50d17ce33826ea2e55d18e936b1f1aeb96342"
  },
  "devDependencies": {
    "@sinonjs/fake-timers": "^15.0.0",
    "cross-env": "^10.1.0",
    "electron": "43.1.0",
    "jasmine": "^6.3.0",
    "sinon": "^22.0.0",
    "space-pencil": "0.3.0"
  }
}

{
  "name": "@lumine-code/atom-keymap",
  "author": "lumine-code",
  "version": "10.0.0",
  "description": "Provides DOM-aware keymap management for Lumine and Electron applications.",
  "main": "./src/keymap-manager",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); for (const path of ['lib', 'api.json']) fs.rmSync(path, {recursive:true, force:true})\"",
    "test": "electron --no-sandbox spec/support/runner",
    "test-drive": "cross-env SUPPRESS_EXIT=true electron --no-sandbox spec/support/runner",
    "rebuild": "electron-rebuild -f -w keyboard-layout"
  },
  "repository": "https://github.com/lumine-code/atom-keymap",
  "bugs": "https://github.com/lumine-code/atom-keymap/issues",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@electron/rebuild": "^4.2.0",
    "clear-cut": "^2",
    "event-kit": "^2.5.3",
    "@lumine-code/fs-plus": "https://github.com/lumine-code/fs-plus.git#6be512460cd7a6d617277f9608b3fcba264cb3be",
    "grim": "^2.0.3",
    "@lumine-code/keyboard-layout": "https://github.com/lumine-code/keyboard-layout.git#925a7d94243fa2ef3e971513feea36b85374a3de",
    "@lumine-code/pathwatcher": "https://github.com/lumine-code/node-pathwatcher.git#a3f906dbddc9ae21e21873b33a6e25a70fd4f4f0",
    "@lumine-code/season": "https://github.com/lumine-code/season.git#721e25f3a41fd9b73419bba7af5057c1a006fd5d"
  },
  "devDependencies": {
    "@sinonjs/fake-timers": "^15.0.0",
    "cross-env": "^10.1.0",
    "electron": "43.1.0",
    "jasmine": "^6.3.0",
    "sinon": "^22.0.0",
    "space-pencil": "0.3.0"
  }
}
